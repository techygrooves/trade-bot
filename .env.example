# Copy to .env and fill in. NEVER commit the real .env.

# Set to "true" to use Binance Spot Testnet (https://testnet.binance.vision).
# Get testnet keys there. Keep this true until you have validated the bot.
BINANCE_TESTNET=true

# Binance API credentials.
# For LIVE keys: enable spot trading, DISABLE withdrawals, IP-whitelist if you can.
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Telegram alerts (optional in Phase 0). Create a bot via @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
